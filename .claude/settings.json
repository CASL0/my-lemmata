{
  "permissions": {
    "deny": [
      "Read(credentials/)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Write|Edit",
        "hooks": [
          {
            "type": "command",
            "command": "pre-commit run --all-files"
          }
        ]
      }
    ]
  }
}
